# O backend agora cria seu próprio servidor WebDAV interno (mesmo processo), gravando os
# arquivos em DATA_DIR. Não é preciso apontar para um servidor WebDAV externo.
DATA_DIR=./data
INTERNAL_WEBDAV_PORT=8080
WEBDAV_USERNAME=notas
WEBDAV_PASSWORD=troque-esta-senha
WEBDAV_NOTES_DIR=/Notes
# Em branco = gerado automaticamente e salvo em DATA_DIR/.api-token na primeira execução (mesmo
# valor nas próximas vezes). Preencha aqui só se quiser fixar um valor específico.
API_TOKEN=
ALLOWED_ORIGIN=http://localhost:4000
PORT=4000
SERVE_CLIENT=true
