# Onde as notas ficam gravadas de fato no host (pode ser qualquer caminho absoluto ou relativo,
# inclusive outro disco/volume já usado para backup)
NOTES_DATA_DIR=./data

# Credenciais do servidor WebDAV interno (criado automaticamente pelo próprio container — não é
# um serviço externo). Deixe em branco pra gerar automaticamente na primeira execução (o valor
# fica salvo em NOTES_DATA_DIR e é reaproveitado nas próximas vezes) — só preencha se quiser fixar
# um valor específico.
WEBDAV_USERNAME=notas
WEBDAV_PASSWORD=

# Em branco = gerado automaticamente (mesma lógica do WEBDAV_PASSWORD acima).
API_TOKEN=

ALLOWED_ORIGIN=https://notas.seudominio.com
CADDY_NETWORK_NAME=caddy_net

# Tag da imagem publicada em hub.docker.com/r/rodrigogossi/notas (latest, ou uma versão/sha fixa)
NOTAS_TAG=latest
